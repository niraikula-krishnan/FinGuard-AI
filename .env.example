# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Optional: enables AI-generated audit reports (falls back to rule-based engine if unset)
GEMINI_API_KEY=your_gemini_api_key_here

# MySQL connection (optional — omit MYSQL_HOST for in-memory demo mode on Hugging Face)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=loan
